{
  "expo": {
    "name": "Hirekar",
    "slug": "hirekar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "hirekar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#a4db5d",
        "foregroundImage": "./src/assets/images/icon.png",
        "backgroundImage": "./src/assets/images/icon.png",
        "monochromeImage": "./src/assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shawnferns2003.hirekar",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#a4db5d"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "@rnmapbox/maps",
        {
          "MAPBOX_DOWNLOADS_TOKEN": "sk.eyJ1Ijoic2hhd25mZXJuczAwNDI2IiwiYSI6ImNtbG5ldHBocDBxbWgzZHM5NWZrbzVzZGcifQ.FhFEjHw-UQ32OtcMc7tuGA"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#a4db5d"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f61f4db-a48d-4986-86b6-d776ff0c339f"
      }
    }
  }
}
